<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.health.ui.controllers.auth.RegisterController"
            fitToWidth="true" fitToHeight="true"
            styleClass="root-scroll"
            vbarPolicy="AS_NEEDED" hbarPolicy="NEVER">

    <StackPane fx:id="root" styleClass="root-container" minHeight="700">

        <!-- Background -->
        <ImageView fx:id="bgImage" preserveRatio="false" smooth="true" cache="true"
                   pickOnBounds="true" styleClass="bg-image">
            <image><Image url="/images/bg.jpg" backgroundLoading="true"/></image>
        </ImageView>
        <Pane styleClass="bg-overlay"/>

        <!-- Centered Form -->
        <VBox alignment="CENTER" styleClass="centering-wrapper">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

            <!-- Glass Panel -->
            <VBox maxWidth="440" styleClass="glass-panel">
                <padding><Insets top="20" right="28" bottom="16" left="28"/></padding>

                <!-- Header (always visible) -->
                <Label text="Create Account" styleClass="brand-logo"/>
                <Label text="Join HealthAssist today" styleClass="login-subtitle"/>

                <Region prefHeight="8"/>

                <!-- Role Tabs (always visible) -->
                <HBox spacing="4" styleClass="role-tabs" alignment="CENTER">
                    <ToggleButton fx:id="patientTab" text="Patient" selected="true"
                                  styleClass="role-tab" onAction="#onPatientTab"/>
                    <ToggleButton fx:id="doctorTab" text="Doctor"
                                  styleClass="role-tab" onAction="#onDoctorTab"/>
                    <ToggleButton fx:id="adminTab" text="Admin"
                                  styleClass="role-tab" onAction="#onAdminTab"/>
                </HBox>

                <Region prefHeight="6"/>

                <!-- Scrollable Form Content -->
                <ScrollPane fitToWidth="true" styleClass="form-scroll"
                            vbarPolicy="AS_NEEDED" hbarPolicy="NEVER"
                            maxHeight="380">
                    <VBox spacing="5">

                        <!-- Common Fields -->
                        <VBox spacing="3"><Label text="Username" styleClass="field-label"/>
                            <TextField fx:id="usernameField" promptText="Choose a username" styleClass="input-field" maxWidth="Infinity"/>
                        </VBox>
                        <VBox spacing="3"><Label text="Email" styleClass="field-label"/>
                            <TextField fx:id="emailField" promptText="you@example.com" styleClass="input-field" maxWidth="Infinity"/>
                        </VBox>
                        <VBox spacing="3"><Label text="Password" styleClass="field-label"/>
                            <PasswordField fx:id="passwordField" promptText="Min 8 characters" styleClass="input-field" maxWidth="Infinity"/>
                        </VBox>
                        <VBox spacing="3"><Label text="Confirm Password" styleClass="field-label"/>
                            <PasswordField fx:id="confirmPasswordField" promptText="Re-enter password" styleClass="input-field" maxWidth="Infinity"/>
                        </VBox>

                        <HBox spacing="10">
                            <VBox spacing="3" HBox.hgrow="ALWAYS"><Label text="First Name" styleClass="field-label"/>
                                <TextField fx:id="firstNameField" promptText="First" styleClass="input-field" maxWidth="Infinity"/>
                            </VBox>
                            <VBox spacing="3" HBox.hgrow="ALWAYS"><Label text="Last Name" styleClass="field-label"/>
                                <TextField fx:id="lastNameField" promptText="Last" styleClass="input-field" maxWidth="Infinity"/>
                            </VBox>
                        </HBox>

                        <VBox spacing="3"><Label text="Gender" styleClass="field-label"/>
                            <ComboBox fx:id="genderCombo" promptText="Select gender" styleClass="input-field" maxWidth="Infinity"/>
                        </VBox>

                        <VBox spacing="3"><Label text="Phone" styleClass="field-label"/>
                            <TextField fx:id="phoneField" promptText="+251-9XX-XXXXXX" styleClass="input-field" maxWidth="Infinity"/>
                        </VBox>

                        <!-- Patient Fields -->
                        <VBox fx:id="patientFields" spacing="5">
                            <HBox spacing="10">
                                <VBox spacing="3" HBox.hgrow="ALWAYS"><Label text="Date of Birth" styleClass="field-label"/>
                                    <TextField fx:id="dobField" promptText="YYYY-MM-DD" styleClass="input-field" maxWidth="Infinity"/>
                                </VBox>
                                <VBox spacing="3" HBox.hgrow="ALWAYS"><Label text="Blood Group" styleClass="field-label"/>
                                    <ComboBox fx:id="bloodCombo" promptText="Select" styleClass="input-field" maxWidth="Infinity"/>
                                </VBox>
                            </HBox>
                            <VBox spacing="3"><Label text="Address" styleClass="field-label"/>
                                <TextField fx:id="addressField" promptText="Your address" styleClass="input-field" maxWidth="Infinity"/>
                            </VBox>
                        </VBox>

                        <!-- Doctor Fields -->
                        <VBox fx:id="doctorFields" visible="false" managed="false" spacing="5">
                            <VBox spacing="3"><Label text="License Number" styleClass="field-label"/>
                                <TextField fx:id="licenseField" promptText="ETH-MC-XXXX-XXXXX" styleClass="input-field" maxWidth="Infinity"/>
                            </VBox>
                            <VBox spacing="3"><Label text="Years of Experience" styleClass="field-label"/>
                                <TextField fx:id="expField" promptText="e.g. 10" styleClass="input-field" maxWidth="Infinity"/>
                            </VBox>
                            <VBox spacing="3"><Label text="Clinic Address" styleClass="field-label"/>
                                <TextField fx:id="clinicField" promptText="Clinic location" styleClass="input-field" maxWidth="Infinity"/>
                            </VBox>
                            <VBox spacing="3"><Label text="Specializations (comma-separated)" styleClass="field-label"/>
                                <TextField fx:id="specField" promptText="Cardiology, General Medicine" styleClass="input-field" maxWidth="Infinity"/>
                            </VBox>
                        </VBox>

                        <!-- Admin Fields -->
                        <VBox fx:id="adminFields" visible="false" managed="false" spacing="5">
                            <VBox spacing="3"><Label text="Department" styleClass="field-label"/>
                                <TextField fx:id="deptField" promptText="e.g. IT, HR" styleClass="input-field" maxWidth="Infinity"/>
                            </VBox>
                            <VBox spacing="3"><Label text="Access Level (1-5)" styleClass="field-label"/>
                                <TextField fx:id="accessField" promptText="1" styleClass="input-field" maxWidth="Infinity"/>
                            </VBox>
                        </VBox>

                        <!-- Error / Success -->
                        <Label fx:id="errorLabel" visible="false" managed="false" wrapText="true" maxWidth="Infinity" styleClass="error-label"/>
                        <Label fx:id="successLabel" visible="false" managed="false" wrapText="true" maxWidth="Infinity" styleClass="success-label"/>

                    </VBox>
                </ScrollPane>

                <Region prefHeight="6"/>

                <!-- Footer (always visible) -->
                <Button fx:id="registerBtn" text="Create Account" onAction="#onRegister" maxWidth="Infinity" styleClass="btn-primary"/>

                <Region prefHeight="4"/>

                <HBox alignment="CENTER" spacing="4">
                    <Label text="Already have an account?" styleClass="hint-text"/>
                    <Hyperlink text="Sign In" onAction="#goToLogin" styleClass="link-text"/>
                </HBox>
            </VBox>
        </VBox>
    </StackPane>
</ScrollPane>