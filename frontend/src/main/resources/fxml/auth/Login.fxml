<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<!--
    IMPORTANT: Do NOT use ${root.width} / ${root.height} on ImageView in FXML.
    JavaFX resolves the expression against the nearest named node (the VBox),
    not the StackPane, producing a NumberFormatException at layout time.
    Instead, we bind fitWidth/fitHeight programmatically in the controller
    after the scene is attached (see LoginController.java).
-->
<StackPane fx:id="root"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.health.ui.controllers.auth.LoginController"
           styleClass="root-container">

    <!-- ══════════════════════════════
         FULLSCREEN BACKGROUND IMAGE
         (binding done in controller)
         ══════════════════════════════ -->
    <ImageView fx:id="bgImage"
               preserveRatio="false"
               smooth="true"
               cache="true"
               pickOnBounds="true"
               styleClass="bg-image">
        <image>
            <Image url="/images/bg.jpg" backgroundLoading="true"/>
        </image>
    </ImageView>

    <!-- DARK OVERLAY — auto-fills the StackPane -->
    <Pane styleClass="bg-overlay"/>

    <!-- ══════════════════════════════
         GLASS LOGIN CARD
         ══════════════════════════════ -->
    <VBox fx:id="loginCard"
          alignment="CENTER"
          spacing="12"
          prefWidth="400"
          prefHeight="500"
          maxHeight="500"
          maxWidth="440"
          styleClass="glass-panel"
          StackPane.alignment="CENTER">

        <padding>
            <Insets top="32" right="36" bottom="32" left="36"/>
        </padding>

        <!-- BRAND -->
        <Label text="HealthAssist" styleClass="brand-logo"/>
        <Label text="Sign in to continue" styleClass="login-subtitle"/>

        <Region prefHeight="6"/>

        <!-- EMAIL -->
        <VBox spacing="5">
            <Label text="Email Address" styleClass="field-label"/>
            <TextField fx:id="emailField"
                       promptText="you@example.com"
                       styleClass="input-field"
                       maxWidth="Infinity"/>
        </VBox>

        <!-- PASSWORD -->
        <VBox spacing="5">
            <Label text="Password" styleClass="field-label"/>
            <PasswordField fx:id="passwordField"
                           promptText="Enter your password"
                           styleClass="input-field"
                           maxWidth="Infinity"/>
        </VBox>

        <!-- ERROR — takes no space when hidden -->
        <Label fx:id="errorLabel"
               visible="false"
               managed="false"
               wrapText="true"
               maxWidth="Infinity"
               styleClass="error-label"/>

        <!-- SIGN IN -->
        <Button fx:id="loginBtn"
                text="Sign In"
                onAction="#onLogin"
                maxWidth="Infinity"
                styleClass="btn-primary"/>

        <!-- REGISTER LINK -->
        <HBox alignment="CENTER" spacing="4">
            <Label text="Don't have an account?" styleClass="hint-text"/>
            <Hyperlink text="Register" onAction="#goToRegister" styleClass="link-text"/>
        </HBox>

        <!-- DIVIDER -->
        <HBox alignment="CENTER" spacing="10">
            <Region HBox.hgrow="ALWAYS" styleClass="divider-line"/>
            <Label text="or" styleClass="divider-text"/>
            <Region HBox.hgrow="ALWAYS" styleClass="divider-line"/>
        </HBox>

        <!-- GOOGLE -->
        <Button onAction="#onGoogleSignIn"
                maxWidth="Infinity"
                styleClass="btn-google">
            <graphic>
                <HBox alignment="CENTER" spacing="10">
                    <Label text="G" styleClass="google-logo-text"/>
                    <Label text="Continue with Google" styleClass="google-btn-text"/>
                </HBox>
            </graphic>
        </Button>

    </VBox>

</StackPane>
